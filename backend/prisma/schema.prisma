// 這是 Prisma Schema 檔案 (最終版 - 支援倉庫尺寸和附加服務)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 1. 會員 (客戶) 資料模型 ---
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  phone        String?
  defaultAddress String?
  role         String     @default("USER") // USER 或 ADMIN
  isActive     Boolean    @default(true)  // 來自 RUNPIGGY-V2

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  packages     Package[]  // 關聯：一個會員可以有多個包裹
  shipments    Shipment[] // 關聯：一個會員可以有多張集運單
}

// --- 2. 包裹 (預報) 資料模型 ---
model Package {
  id              String    @id @default(cuid())
  trackingNumber  String
  productName     String
  quantity        Int       @default(1)
  note            String?
  productImages   String    @default("[]") // 會員上傳的圖片
  status          String    @default("PENDING") // PENDING, ARRIVED, IN_SHIPMENT, COMPLETED

  // --- (新) 倉庫回填欄位 (參考 RUNPIGGY-V2) ---
  actualWeight    Float?    // 實際重量 (kg)
  actualLength    Float?    // 實際長 (cm)
  actualWidth     Float?    // 實際寬 (cm)
  actualHeight    Float?    // 實際高 (cm)
  actualCbm       Float?    // 實際 CBM (方) (由後端自動計算)
  warehouseImages String    @default("[]") // 倉庫拍的照片
  
  // --- (新) 為了讓管理員能自動計算運費 ---
  furnitureType   String?   // 會員預報時填寫的 "家具類型" (例如: general, special_a)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  // 關聯：這個包裹屬於哪個 "會員"
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  // 關聯：這個包裹屬於哪張 "集運單" (可選)
  shipmentId      String?
  shipment        Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([userId])
  @@index([shipmentId])
}

// --- 3. 集運單資料模型 ---
model Shipment {
  id              String    @id @default(cuid())
  
  // 收件人資訊 (報關用)
  recipientName   String
  phone           String
  shippingAddress String
  idNumber        String    // 身分證
  taxId           String?   // 統一編號

  // --- (新) 附加服務 (參考 RUNPIGGY-V2) ---
  additionalServices String?  // 儲存 JSON: {"wooden_crate": true, "inspection": false}
  
  // --- (新) 為了讓管理員能自動計算運費 ---
  deliveryLocationRate Float? // 儲存偏遠地區費率 (例如: 0, 1800, 4500)

  status          String    @default("PENDING_PAYMENT") // PENDING_PAYMENT, PROCESSING, SHIPPED, COMPLETED
  totalCost       Float?    // 最終運費 (由管理員填寫)
  trackingNumberTW String?   // 台灣物流單號

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  // 關聯
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  packages        Package[] // 這張單包含的包裹

  @@index([userId])
}

// --- 4. 估價單 (分享連結用) 資料模型 ---
// (參考 RUNPIGGY-V2)
model CalculationQuote {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  calculationResult String    // 儲存 JSON 字串
}