// 這是 backend/prisma/schema.prisma (支援分箱的修改版)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 1. 會員 (客戶) 資料模型 ---
model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  name           String?
  phone          String?
  defaultAddress String?
  role           String     @default("USER") // USER, ADMIN, OPERATOR
  isActive       Boolean    @default(true)   // 帳號啟用狀態

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  packages       Package[]  // 關聯：一個會員可以有多個包裹
  shipments      Shipment[] // 關聯：一個會員可以有多張集運單
}

// --- 2. 包裹 (預報) 資料模型 ---
model Package {
  id              String    @id @default(cuid())
  
  trackingNumber  String    // 物流單號
  productName     String    // 商品名稱
  quantity        Int       @default(1)
  note            String?
  productImages   String    @default("[]") // 會員上傳的圖片 (JSON string)
  status          String    @default("PENDING") // PENDING, ARRIVED, IN_SHIPMENT, COMPLETED

  // --- 倉庫回填欄位 (*** 修改重點 ***) ---
  
  // [移除] actualWeight, actualLength, actualWidth, actualHeight, actualCbm, furnitureType, shippingFee

  // [新增] 儲存分箱的陣列 (JSON 字串)
  // 例如: "[{ "name": "分箱1", "weight": 10.5, "length": 80, ... "fee": 2250 }]"
  arrivedBoxesJson String?   @default("[]") 
  
  // [新增] 儲存所有分箱的運費總和
  totalCalculatedFee Float?

  // 倉庫拍的照片 (JSON string)
  warehouseImages String    @default("[]") 
  
  // 倉庫人員填寫的備註 (給客戶看)
  warehouseRemark String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  // 關聯：屬於哪個會員
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  // 關聯：屬於哪張集運單 (可選)
  shipmentId      String?
  shipment        Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([userId])
  @@index([shipmentId])
}

// --- 3. 集運單資料模型 ---
model Shipment {
  id                   String    @id @default(cuid())
  
  // 收件人資訊
  recipientName        String
  phone                String
  shippingAddress      String
  idNumber             String    // 身分證
  taxId                String?   // 統一編號
  note                 String?   // 客戶備註

  // 附加服務 & 費用
  additionalServices   String?   // JSON (雖然前端拿掉了，但資料庫保留無妨)
  deliveryLocationRate Float?    // 偏遠地區費率
  
  status               String    @default("PENDING_PAYMENT") // PENDING_PAYMENT, PROCESSING, SHIPPED, COMPLETED, CANCELLED
  totalCost            Float?    // 最終總運費 (建立時自動計算)
  trackingNumberTW     String?   // 台灣物流單號
  paymentProof         String?   // 付款憑證圖片路徑

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt

  // 關聯
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  packages             Package[] // 這張單包含的包裹

  @@index([userId])
}

// --- 4. 估價單 (分享連結用) ---
model CalculationQuote {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  calculationResult String    // 儲存 JSON 字串
}