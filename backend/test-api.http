### 測試 (V3) - 建立集運單 (含附加服務)
POST http://localhost:3000/api/shipments/create
Content-Type: application/json
Authorization: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6ImNtaHU0czMxYTAwMDBndjdjd3llbGFuZ3QiLCJpYXQiOjE3NjI5MTY0OTUsImV4cCI6MTc2NTUwODQ5NX0.XTxb1xRyFFyqQhgDNHU5kKQMd8HnFStOvIzSCGQQoOo"

{
  "packageIds": ["YOUR_PACKAGE_ID_HERE"],
  "recipientName": "王小明",
  "phone": "0912345678",
  "shippingAddress": "台灣省台北市信義區市府路1號",
  "idNumber": "A123456789",
  "taxId": "87654321",
  "additionalServices": {
    "wooden_crate": true,
    "inspection": false,
    "strengthen": true
  }
}